generator client {
  provider = "prisma-client-js"
}
generator seed {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════
// AUTH
// ═══════════════════════════════════════════════
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ═══════════════════════════════════════════════
// LOẠI PHÒNG
// ═══════════════════════════════════════════════
model LoaiPhong {
  maLoaiPhong   Int      @id @default(autoincrement())
  dienTich      Float?
  isMayLanh     Boolean?
  soNguoiToiDa  Int?
  giaTien       Decimal? @db.Decimal(10, 2)

  phong         Phong[]

  @@map("loaiphong")
}

// ═══════════════════════════════════════════════
// PHÒNG
// ═══════════════════════════════════════════════
model Phong {
  phongId     Int     @id @default(autoincrement()) @map("PhongID")
  tenPhong    String?
  trangThai   String?
  moTa        String? @db.Text
  maLoaiPhong Int?

  loaiPhong           LoaiPhong?            @relation(fields: [maLoaiPhong], references: [maLoaiPhong])
  dienNuoc            DienNuoc[]
  hopDong             HopDong[]
  lapRap              LapRap[]
  suaChua             SuaChua[]
  nguoiLuuTruTamThoi  NguoiLuuTruTamThoi[]

  @@map("phong")
}

// ═══════════════════════════════════════════════
// NGƯỜI THUÊ
// ═══════════════════════════════════════════════
model NguoiThue {
  idnt      Int       @id @default(autoincrement()) @map("IDNT")
  cccd      String?   @map("CCCD")
  hoTen     String?
  ngaySinh  DateTime? @db.Date
  sdt       String?   @map("SDT")
  queQuan   String?
  ghiChu    String?   @db.Text

  hopDong       HopDong[]
  phuongTien    PhuongTien[]
  hoaDonTapHoa  HoaDonTapHoa[]

  @@map("nguoithue")
}

// ═══════════════════════════════════════════════
// HỢP ĐỒNG
// ═══════════════════════════════════════════════
model HopDong {
  hopDongId      Int       @id @default(autoincrement()) @map("HopDongID")
  idnt           Int?      @map("IDNT")
  phongId        Int?      @map("PhongID")
  ngayKy         DateTime? @db.Date
  ngayHetHan     DateTime? @db.Date
  tienCoc        Decimal?  @db.Decimal(10, 2)
  giaPhongThucTe Decimal?  @db.Decimal(10, 2)
  trangThai      String?

  nguoiThue   NguoiThue?    @relation(fields: [idnt], references: [idnt])
  phong       Phong?        @relation(fields: [phongId], references: [phongId])
  hoaDonPhong HoaDonPhong[]

  @@map("hopdong")
}

// ═══════════════════════════════════════════════
// ĐIỆN NƯỚC
// ═══════════════════════════════════════════════
model DienNuoc {
  idDienNuoc Int     @id @default(autoincrement())
  phongId    Int?    @map("PhongID")
  thangNam   String?
  chiSoDien  Int?
  chiSoNuoc  Int?

  phong      Phong?  @relation(fields: [phongId], references: [phongId])

  @@map("diennuoc")
}

// ═══════════════════════════════════════════════
// HÓA ĐƠN PHÒNG
// ═══════════════════════════════════════════════
model HoaDonPhong {
  maHoaDon  Int      @id @default(autoincrement())
  thangNam  String?
  soTien    Decimal? @db.Decimal(10, 2)
  hopDongId Int?     @map("HopDongID")

  hopDong             HopDong?            @relation(fields: [hopDongId], references: [hopDongId])
  phieuThuHangThang   PhieuThuHangThang[]

  @@map("hoadonphong")
}

// ═══════════════════════════════════════════════
// PHIẾU THU HÀNG THÁNG
// ═══════════════════════════════════════════════
model PhieuThuHangThang {
  maPhieuThu Int       @id @default(autoincrement())
  ngayThu    DateTime? @db.Date
  soTien     Decimal?  @db.Decimal(10, 2)
  ghiChu     String?   @db.Text
  maHoaDon   Int?

  hoaDonPhong HoaDonPhong? @relation(fields: [maHoaDon], references: [maHoaDon])

  @@map("phieuthuhangthang")
}

// ═══════════════════════════════════════════════
// PHƯƠNG TIỆN (PK = string bienSo)
// ═══════════════════════════════════════════════
model PhuongTien {
  bienSo  String  @id
  hangXe  String?
  mauSac  String?
  idnt    Int?    @map("IDNT")

  nguoiThue   NguoiThue?    @relation(fields: [idnt], references: [idnt])
  hoaDonGuiXe HoaDonGuiXe[]

  @@map("phuongtien")
}

// ═══════════════════════════════════════════════
// HÓA ĐƠN GỬI XE
// ═══════════════════════════════════════════════
model HoaDonGuiXe {
  maHoaDon Int     @id @default(autoincrement())
  thangNam String?
  soTien   Decimal? @db.Decimal(10, 2)
  bienSo   String?

  phuongTien PhuongTien? @relation(fields: [bienSo], references: [bienSo])

  @@map("hoadonguixe")
}

// ═══════════════════════════════════════════════
// HÀNG HÓA
// ═══════════════════════════════════════════════
model HangHoa {
  maHangHoa  Int     @id @default(autoincrement())
  tenHangHoa String?
  giaNhap    Decimal? @db.Decimal(10, 2)
  giaBan     Decimal? @db.Decimal(10, 2)

  chiTietTapHoa ChiTietTapHoa[]

  @@map("hanghoa")
}

// ═══════════════════════════════════════════════
// HÓA ĐƠN TẠP HÓA
// ═══════════════════════════════════════════════
model HoaDonTapHoa {
  maHoaDon Int       @id @default(autoincrement())
  idnt     Int?      @map("IDNT")
  ngayBan  DateTime? @db.Date
  tongTien Decimal?  @db.Decimal(10, 2)

  nguoiThue     NguoiThue?      @relation(fields: [idnt], references: [idnt])
  chiTietTapHoa ChiTietTapHoa[]
  phieuThuHdTh  PhieuThuHdTh[]

  @@map("hoadontaphoa")
}

// ═══════════════════════════════════════════════
// CHI TIẾT TẠP HÓA
// ═══════════════════════════════════════════════
model ChiTietTapHoa {
  maChiTietHoaDon Int @id @default(autoincrement())
  maHoaDon        Int?
  maHangHoa       Int?
  soLuong         Int?

  hoaDonTapHoa HoaDonTapHoa? @relation(fields: [maHoaDon], references: [maHoaDon])
  hangHoa      HangHoa?      @relation(fields: [maHangHoa], references: [maHangHoa])

  @@map("chitiettaphoa")
}

// ═══════════════════════════════════════════════
// PHIẾU THU HĐ TẠP HÓA
// ═══════════════════════════════════════════════
model PhieuThuHdTh {
  maPhieuThu Int       @id @default(autoincrement())
  ngayThu    DateTime? @db.Date
  soTien     Decimal?  @db.Decimal(10, 2)
  nguoiDong  String?
  maHoaDon   Int?

  hoaDonTapHoa HoaDonTapHoa? @relation(fields: [maHoaDon], references: [maHoaDon])

  @@map("phieuthuhdth")
}

// ═══════════════════════════════════════════════
// THIẾT BỊ
// ═══════════════════════════════════════════════
model ThietBi {
  thietBiId  Int       @id @default(autoincrement()) @map("thietBiID")
  tenThietBi String?
  loai       String?
  giaTri     Decimal?  @db.Decimal(10, 2)
  ngayMua    DateTime? @db.Date
  trangThai  String?

  lapRap LapRap[]

  @@map("thietbi")
}

// ═══════════════════════════════════════════════
// LẮP RÁP (junction Phong <-> ThietBi)
// ═══════════════════════════════════════════════
model LapRap {
  id        Int       @id @default(autoincrement())
  phongId   Int?      @map("PhongID")
  thietBiId Int?      @map("thietBiID")
  ngayLap   DateTime? @db.Date
  soLuong   Int?

  phong   Phong?   @relation(fields: [phongId], references: [phongId])
  thietBi ThietBi? @relation(fields: [thietBiId], references: [thietBiId])

  @@map("laprap")
}

// ═══════════════════════════════════════════════
// SỬA CHỮA
// ═══════════════════════════════════════════════
model SuaChua {
  id           Int       @id @default(autoincrement())
  phongId      Int?      @map("PhongID")
  nguyenNhan   String?   @db.Text
  ngaySuaChua  DateTime? @db.Date

  phong          Phong?          @relation(fields: [phongId], references: [phongId])
  hoaDonSuaChua  HoaDonSuaChua[]

  @@map("suachua")
}

// ═══════════════════════════════════════════════
// HÓA ĐƠN SỬA CHỮA
// ═══════════════════════════════════════════════
model HoaDonSuaChua {
  maHoaDonSc      Int       @id @default(autoincrement()) @map("maHoaDonSC")
  trangThai       String?   @map("TrangThai")
  giaTien         Decimal?  @db.Decimal(10, 2)
  loaiSua         String?
  ngayLapHoaDonSc DateTime? @db.Date @map("ngayLapHoaDonSC")
  suaChuaId       Int?      @map("id")

  suaChua SuaChua? @relation(fields: [suaChuaId], references: [id])

  @@map("hoadonsuachua")
}

// ═══════════════════════════════════════════════
// NGƯỜI LƯU TRÚ TẠM THỜI
// ═══════════════════════════════════════════════
model NguoiLuuTruTamThoi {
  idtt     Int       @id @default(autoincrement()) @map("IDTT")
  hoTen    String?
  cccd     String?   @map("CCCD")
  ngaySinh DateTime? @db.Date
  sdt      String?   @map("SDT")
  queQuan  String?
  phongId  Int?      @map("PhongID")

  phong    Phong?    @relation(fields: [phongId], references: [phongId])

  @@map("nguoiluutrutamthoi")
}
